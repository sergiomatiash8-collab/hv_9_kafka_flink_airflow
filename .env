# Kafka Configuration
# Для Docker використовуй kafka:29092
# Для локального запуску використовуй localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=tweets
KAFKA_GROUP_ID=tweet-processor

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tweets_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Application
CSV_FILE_PATH=data/raw_tweets.csv
LOG_LEVEL=INFO
# Kafka
# Для контейнерів (Producer/Worker) використовуємо внутрішній хост
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=tweets
KAFKA_GROUP_ID=tweet-processor

# PostgreSQL
# Для контейнерів використовуємо назву сервісу 'postgres'
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tweets_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Application
CSV_FILE_PATH=data/raw_tweets.csv
LOG_LEVEL=INFO
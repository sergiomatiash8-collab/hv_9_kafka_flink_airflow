# З'єднання з Kafka (використовуємо внутрішню назву сервісу в Docker)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=tweets

# З'єднання з Базою Даних (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tweets_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Налаштування прав Airflow (щоб не було проблем з доступом до папок)
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Налаштування Flink
FLINK_PARALLELISM=1
OUTPUT_DIR=/opt/flink/usrlib/output